!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Environment
.env
.env.local
.env.*.local
.env.development
.env.production

# Build output
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

